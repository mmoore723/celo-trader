# ─── AlgoTrader Pro — Environment Variables ───────────────────────────────────
# Copy this file to .env and fill in your credentials.
# NEVER commit .env to Git (it's in .gitignore).

# ── Alpaca (required) ─────────────────────────────────────────────────────────
# Get your keys at: https://app.alpaca.markets/paper/dashboard/overview
ALPACA_API_KEY=your_alpaca_api_key_here
ALPACA_SECRET_KEY=your_alpaca_secret_key_here

# Set to "true" for paper trading (STRONGLY recommended while testing)
# Set to "false" only when you're ready to trade real money
ALPACA_PAPER=true

# ── Tradier (recommended for options data) ────────────────────────────────────
# Sign up at: https://developer.tradier.com/
# Free sandbox: https://sandbox.tradier.com/v1
# Live trading: https://api.tradier.com/v1 (requires funded brokerage account)
TRADIER_API_KEY=your_tradier_api_key_here
TRADIER_BASE_URL=https://sandbox.tradier.com/v1

# ── Polygon.io (optional — real-time options data) ────────────────────────────
# Without this key, options data has a 15-minute delay
# Free tier at: https://polygon.io/
POLYGON_API_KEY=

# ── Authentication ────────────────────────────────────────────────────────────
# Random secret used to sign session JWTs. Generate one with:
#   python3 -c "import secrets; print(secrets.token_hex(32))"
JWT_SECRET=change-me-generate-a-real-secret

# Dashboard password hash (bcrypt). Generate with:
#   python3 -c "from passlib.hash import bcrypt; print(bcrypt.hash('yourpassword'))"
# Then paste the output here. Never store the plain password.
DASHBOARD_PASSWORD_HASH=$2b$12$replace_with_your_generated_hash_here

# Fallback: plaintext password (only for local dev, never use in production)
# DASHBOARD_PASSWORD=mysecretpassword

# ── Email alerts (optional) ───────────────────────────────────────────────────
# Set these to receive email alerts for critical errors
# Use an App Password for Gmail (not your main password):
# https://support.google.com/accounts/answer/185833
ALERT_EMAIL=your_email@gmail.com
ALERT_SMTP_HOST=smtp.gmail.com
ALERT_SMTP_PORT=587
ALERT_SMTP_USER=your_email@gmail.com
ALERT_SMTP_PASS=your_gmail_app_password_here
